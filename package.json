{
  "name": "elpulsar-app",
  "version": "1.0.0",
  "description": "elpulsar.app - Aplicación soberana con Workers y Pages",
  "main": "worker.js",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "build": "npm run build:static",
    "build:static": "mkdir -p dist && cp Sources/index.html dist/ && cp -r Sources/assets dist/ 2>/dev/null || true",
    "deploy:pages": "wrangler pages deploy dist --project-name=elpulsar",
    "test": "jest",
    "lint": "eslint ."
  },
  "keywords": [
    "lacho",
    "dirime",
    "elpulsar",
    "soberano",
    "imv",
    "cloudflare-workers"
  ],
  "author": "LACHO-DIRIME",
  "license": "MIT",
  "devDependencies": {
    "wrangler": "^3.0.0",
    "jest": "^29.0.0",
    "eslint": "^8.0.0"
  },
  "dependencies": {},
  "engines": {
    "node": ">=18.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/LACHO-DIRIME/elpulsar-app.git"
  },
  "bugs": {
    "url": "https://github.com/LACHO-DIRIME/elpulsar-app/issues"
  },
  "homepage": "https://elpulsar.app"
}
